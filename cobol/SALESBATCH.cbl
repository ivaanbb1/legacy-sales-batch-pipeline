       >>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. SALESBATCH.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT SALES-FILE ASSIGN TO "data/input/SALES.DAT"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT PRODUCT-FILE ASSIGN TO "data/input/PRODUCTS.DAT"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT CLEAN-FILE ASSIGN TO "data/output/SALES_CLEAN.csv"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT ERROR-FILE ASSIGN TO "data/output/SALES_ERRORS.csv"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT REPORT-FILE ASSIGN TO "data/output/SALES_REPORT.txt"
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD SALES-FILE.
01 SALES-LINE PIC X(36).

FD PRODUCT-FILE.
01 PRODUCT-LINE PIC X(39).

FD CLEAN-FILE.
01 CLEAN-LINE PIC X(180).

FD ERROR-FILE.
01 ERROR-LINE PIC X(160).

FD REPORT-FILE.
01 REPORT-LINE PIC X(120).

WORKING-STORAGE SECTION.
01 WS-SALES-RECORD.
   05 WS-SALE-DATE        PIC X(8).
   05 WS-CUSTOMER-ID      PIC X(6).
   05 WS-PRODUCT-ID       PIC X(6).
   05 WS-QUANTITY         PIC 9(5).
   05 WS-UNIT-PRICE-CENTS PIC 9(8).
   05 WS-CHANNEL          PIC X(3).

01 PRODUCT-TABLE.
   05 PRODUCT-ENTRY OCCURS 50 TIMES.
      10 T-PRODUCT-ID     PIC X(6).
      10 T-PRODUCT-NAME   PIC X(20).
      10 T-CATEGORY       PIC X(12).
      10 T-ACTIVE-FLAG    PIC X.

01 WS-FLAGS.
   05 EOF-SALES           PIC X VALUE "N".
   05 EOF-PRODUCTS        PIC X VALUE "N".
   05 PRODUCT-FOUND       PIC X VALUE "N".
   05 RECORD-VALID        PIC X VALUE "Y".

01 WS-COUNTERS.
   05 PRODUCT-COUNT       PIC 9(3) VALUE 0.
   05 SALES-READ          PIC 9(5) VALUE 0.
   05 SALES-ACCEPTED      PIC 9(5) VALUE 0.
   05 SALES-REJECTED      PIC 9(5) VALUE 0.
   05 WS-IDX              PIC 9(3) VALUE 0.
   05 FOUND-IDX           PIC 9(3) VALUE 0.

01 WS-AMOUNTS.
   05 WS-LINE-AMOUNT-CENTS PIC 9(11) VALUE 0.
   05 WS-TOTAL-CENTS       PIC 9(13) VALUE 0.
   05 WS-TOTAL-EUROS       PIC 9(11) VALUE 0.
   05 WS-TOTAL-REMAINDER   PIC 99 VALUE 0.

01 WS-DATE-PARTS.
   05 WS-YEAR             PIC 9(4).
   05 WS-MONTH            PIC 9(2).
   05 WS-DAY              PIC 9(2).

01 WS-ERROR-REASON        PIC X(50).
01 WS-DISPLAY-COUNT       PIC Z(4)9.
01 WS-DISPLAY-CENTS       PIC Z(12)9.
01 WS-DISPLAY-EUROS       PIC Z(10)9.
01 WS-DISPLAY-REMAINDER   PIC 99.

PROCEDURE DIVISION.
MAIN-PROCESS.
    PERFORM OPEN-FILES
    PERFORM LOAD-PRODUCTS
    PERFORM WRITE-HEADERS
    PERFORM PROCESS-SALES UNTIL EOF-SALES = "Y"
    PERFORM WRITE-REPORT
    PERFORM CLOSE-FILES
    STOP RUN.

OPEN-FILES.
    OPEN INPUT SALES-FILE
    OPEN INPUT PRODUCT-FILE
    OPEN OUTPUT CLEAN-FILE
    OPEN OUTPUT ERROR-FILE
    OPEN OUTPUT REPORT-FILE.

CLOSE-FILES.
    CLOSE SALES-FILE PRODUCT-FILE CLEAN-FILE ERROR-FILE REPORT-FILE.

LOAD-PRODUCTS.
    PERFORM UNTIL EOF-PRODUCTS = "Y"
        READ PRODUCT-FILE
            AT END
                MOVE "Y" TO EOF-PRODUCTS
            NOT AT END
                IF PRODUCT-COUNT < 50
                    ADD 1 TO PRODUCT-COUNT
                    MOVE PRODUCT-LINE(1:6) TO T-PRODUCT-ID(PRODUCT-COUNT)
                    MOVE PRODUCT-LINE(7:20) TO T-PRODUCT-NAME(PRODUCT-COUNT)
                    MOVE PRODUCT-LINE(27:12) TO T-CATEGORY(PRODUCT-COUNT)
                    MOVE PRODUCT-LINE(39:1) TO T-ACTIVE-FLAG(PRODUCT-COUNT)
                END-IF
        END-READ
    END-PERFORM.

WRITE-HEADERS.
    MOVE "sale_date,customer_id,product_id,product_name,category,quantity,unit_price_cents,total_amount_cents,channel" TO CLEAN-LINE
    WRITE CLEAN-LINE
    MOVE "sale_date,customer_id,product_id,quantity,unit_price_cents,channel,error_reason" TO ERROR-LINE
    WRITE ERROR-LINE.

PROCESS-SALES.
    READ SALES-FILE
        AT END
            MOVE "Y" TO EOF-SALES
        NOT AT END
            ADD 1 TO SALES-READ
            PERFORM PARSE-SALE
            PERFORM VALIDATE-SALE
            IF RECORD-VALID = "Y"
                PERFORM WRITE-CLEAN-RECORD
            ELSE
                PERFORM WRITE-ERROR-RECORD
            END-IF
    END-READ.

PARSE-SALE.
    MOVE SALES-LINE(1:8)   TO WS-SALE-DATE
    MOVE SALES-LINE(9:6)   TO WS-CUSTOMER-ID
    MOVE SALES-LINE(15:6)  TO WS-PRODUCT-ID
    MOVE SALES-LINE(21:5)  TO WS-QUANTITY
    MOVE SALES-LINE(26:8)  TO WS-UNIT-PRICE-CENTS
    MOVE SALES-LINE(34:3)  TO WS-CHANNEL.

VALIDATE-SALE.
    MOVE "Y" TO RECORD-VALID
    MOVE SPACES TO WS-ERROR-REASON
    PERFORM FIND-PRODUCT

    IF PRODUCT-FOUND = "N"
        MOVE "N" TO RECORD-VALID
        MOVE "Product does not exist" TO WS-ERROR-REASON
    END-IF

    IF PRODUCT-FOUND = "Y" AND T-ACTIVE-FLAG(FOUND-IDX) NOT = "Y"
        MOVE "N" TO RECORD-VALID
        MOVE "Product is inactive" TO WS-ERROR-REASON
    END-IF

    IF WS-QUANTITY = 0
        MOVE "N" TO RECORD-VALID
        MOVE "Quantity must be greater than zero" TO WS-ERROR-REASON
    END-IF

    IF WS-CHANNEL NOT = "WEB" AND WS-CHANNEL NOT = "STO" AND WS-CHANNEL NOT = "APP"
        MOVE "N" TO RECORD-VALID
        MOVE "Invalid sales channel" TO WS-ERROR-REASON
    END-IF

    MOVE WS-SALE-DATE(1:4) TO WS-YEAR
    MOVE WS-SALE-DATE(5:2) TO WS-MONTH
    MOVE WS-SALE-DATE(7:2) TO WS-DAY

    IF WS-YEAR < 2020 OR WS-MONTH < 1 OR WS-MONTH > 12 OR WS-DAY < 1 OR WS-DAY > 31
        MOVE "N" TO RECORD-VALID
        MOVE "Invalid sale date" TO WS-ERROR-REASON
    END-IF.

FIND-PRODUCT.
    MOVE "N" TO PRODUCT-FOUND
    MOVE 0 TO FOUND-IDX
    PERFORM VARYING WS-IDX FROM 1 BY 1
        UNTIL WS-IDX > PRODUCT-COUNT OR PRODUCT-FOUND = "Y"
        IF T-PRODUCT-ID(WS-IDX) = WS-PRODUCT-ID
            MOVE "Y" TO PRODUCT-FOUND
            MOVE WS-IDX TO FOUND-IDX
        END-IF
    END-PERFORM.

WRITE-CLEAN-RECORD.
    MOVE SPACES TO CLEAN-LINE
    COMPUTE WS-LINE-AMOUNT-CENTS = WS-QUANTITY * WS-UNIT-PRICE-CENTS
    ADD WS-LINE-AMOUNT-CENTS TO WS-TOTAL-CENTS
    ADD 1 TO SALES-ACCEPTED

    STRING
        WS-SALE-DATE DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-CUSTOMER-ID DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-PRODUCT-ID DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        T-PRODUCT-NAME(FOUND-IDX) DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        T-CATEGORY(FOUND-IDX) DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-QUANTITY DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-UNIT-PRICE-CENTS DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-LINE-AMOUNT-CENTS DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-CHANNEL DELIMITED BY SIZE
        INTO CLEAN-LINE
    END-STRING
    WRITE CLEAN-LINE.

WRITE-ERROR-RECORD.
    MOVE SPACES TO ERROR-LINE
    ADD 1 TO SALES-REJECTED

    STRING
        WS-SALE-DATE DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-CUSTOMER-ID DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-PRODUCT-ID DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-QUANTITY DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-UNIT-PRICE-CENTS DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-CHANNEL DELIMITED BY SIZE
        "," DELIMITED BY SIZE
        WS-ERROR-REASON DELIMITED BY SIZE
        INTO ERROR-LINE
    END-STRING
    WRITE ERROR-LINE.

WRITE-REPORT.
    MOVE "SALES BATCH - CONTROL REPORT" TO REPORT-LINE
    WRITE REPORT-LINE

    MOVE "-----------------------------------" TO REPORT-LINE
    WRITE REPORT-LINE

    MOVE SPACES TO REPORT-LINE
    MOVE SALES-READ TO WS-DISPLAY-COUNT
    STRING
        "Records read:      " DELIMITED BY SIZE
        WS-DISPLAY-COUNT DELIMITED BY SIZE
        INTO REPORT-LINE
    END-STRING
    WRITE REPORT-LINE

    MOVE SPACES TO REPORT-LINE
    MOVE SALES-ACCEPTED TO WS-DISPLAY-COUNT
    STRING
        "Records accepted:  " DELIMITED BY SIZE
        WS-DISPLAY-COUNT DELIMITED BY SIZE
        INTO REPORT-LINE
    END-STRING
    WRITE REPORT-LINE

    MOVE SPACES TO REPORT-LINE
    MOVE SALES-REJECTED TO WS-DISPLAY-COUNT
    STRING
        "Records rejected:  " DELIMITED BY SIZE
        WS-DISPLAY-COUNT DELIMITED BY SIZE
        INTO REPORT-LINE
    END-STRING
    WRITE REPORT-LINE

    MOVE SPACES TO REPORT-LINE
    MOVE WS-TOTAL-CENTS TO WS-DISPLAY-CENTS
    STRING
        "Accepted cents:    " DELIMITED BY SIZE
        WS-DISPLAY-CENTS DELIMITED BY SIZE
        INTO REPORT-LINE
    END-STRING
    WRITE REPORT-LINE

    DIVIDE WS-TOTAL-CENTS BY 100 GIVING WS-TOTAL-EUROS REMAINDER WS-TOTAL-REMAINDER
    MOVE WS-TOTAL-EUROS TO WS-DISPLAY-EUROS
    MOVE WS-TOTAL-REMAINDER TO WS-DISPLAY-REMAINDER
    MOVE SPACES TO REPORT-LINE
    STRING
        "Accepted amount:   " DELIMITED BY SIZE
        WS-DISPLAY-EUROS DELIMITED BY SIZE
        "." DELIMITED BY SIZE
        WS-DISPLAY-REMAINDER DELIMITED BY SIZE
        " EUR" DELIMITED BY SIZE
        INTO REPORT-LINE
    END-STRING
    WRITE REPORT-LINE.
